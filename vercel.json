{
  "functions": {
    "api/generate.js": {
      "maxDuration": 60,
      "includeFiles": "images/{matte-black-*.webp,showroom-bg.webp}"
    },
    "api/recolor.js": {
      "maxDuration": 60,
      "includeFiles": "images/{matte-black-*.webp,showroom-bg.webp}",
      "memory": 1024
    },
    "api/generate-from-description.js": {
      "maxDuration": 60,
      "includeFiles": "images/{matte-black-*.webp,showroom-bg.webp}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/v2", "destination": "/v2.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
